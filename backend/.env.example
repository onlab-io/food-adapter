# --- App ---
APP_PASSWORD=cambiami
SESSION_SECRET=metti-un-segreto-lungo-e-casuale
CORS_ORIGINS=http://localhost:5173
MAX_FILE_MB=40

# --- Database ---
# Lascia VUOTO per usare SQLite locale (sviluppo/test: ./data/app.db).
# In produzione usa il Postgres di Supabase (Connection string -> "URI", driver psycopg):
# DATABASE_URL=postgresql+psycopg://postgres:<DB_PASSWORD>@db.<REF>.supabase.co:5432/postgres
DATABASE_URL=

# --- Supabase Storage (REST) ---
# Lascia VUOTO per usare lo storage locale (./data/storage).
# In produzione:
# SUPABASE_URL=https://<REF>.supabase.co
# SUPABASE_SERVICE_KEY=<service_role key — MAI esporre al client>
# STORAGE_BUCKET=photo-adapter
SUPABASE_URL=
SUPABASE_SERVICE_KEY=
STORAGE_BUCKET=photo-adapter

# --- Adobe Firefly Services / Photoshop API (Fase 2) ---
# Credenziali OAuth Server-to-Server da Adobe Developer Console (Photoshop API + Firefly API).
# Lascia VUOTO per usare lo stub locale (DEFAULT_RENDER_ENGINE=local), che collauda il flusso a costo zero.
ADOBE_CLIENT_ID=
ADOBE_CLIENT_SECRET=
# Stability AI (outpaint) — chiave self-service da https://platform.stability.ai
STABILITY_API_KEY=
DEFAULT_RENDER_ENGINE=local
COSTO_PER_OPERAZIONE_AI=0.04
